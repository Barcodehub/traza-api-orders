                  "});",
                  "console.log(\"🔴 Inventory-service: Forced failure ENABLED\");"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{inventory_service_url}}/test/failure?enable=true",
              "host": ["{{inventory_service_url}}"],
              "path": ["test", "failure"],
              "query": [{"key": "enable", "value": "true"}]
            },
            "description": "Activar fallo forzado en inventory-service. El siguiente request fallará en la reserva de inventario PERO COMPENSARÁ el pago."
          }
        },
        {
          "name": "3️⃣ Crear Orden (fallará en Inventory)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status es 400 (Bad Request)\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Response tiene mensaje de error\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.not.be.empty;",
                  "});",
                  "",
                  "console.log(\"WARNING: Check LOGS to see COMPENSATION:\");",
                  "console.log(\"   [SAGA:xxx] Payment SUCCESS\");",
                  "console.log(\"   [SAGA:xxx] Inventory reservation FAILED\");",
                  "console.log(\"   [SAGA:xxx] Compensating: refunding payment <-- COMPENSATION\");",
                  "console.log(\"   [SAGA:xxx] Payment refunded\");",
                  "console.log(\"   [SAGA:xxx] Order CANCELLED\");"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-scenario3-inventory-fail\",\n  \"total\": 300.00\n}"
            },
            "url": {
              "raw": "{{order_service_url}}/orders",
              "host": ["{{order_service_url}}"],
              "path": ["orders"]
            },
            "description": "Crear una orden cuando inventory-service está forzado a fallar.\n\n⚠️ IMPORTANTE: Revisa los LOGS EN LAS TERMINALES para ver:\n1. Payment procesado exitosamente\n2. Inventory falla\n3. COMPENSACIÓN: Payment es reembolsado automáticamente\n4. Orden termina en CANCELLED"
          }
        },
        {
          "name": "4️⃣ Restaurar Inventory Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Failure mode disabled\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "console.log(\"🟢 Inventory-service: Forced failure DISABLED\");"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{inventory_service_url}}/test/failure?enable=false",
              "host": ["{{inventory_service_url}}"],
              "path": ["test", "failure"],
              "query": [{"key": "enable", "value": "false"}]
            },
            "description": "Desactivar fallo forzado en inventory-service (vuelve a modo aleatorio 20%)"
          }
        }
      ]
    },
    {
      "name": "🎲 Test Aleatorio (sin fallos forzados)",
      "description": "Crear órdenes con fallos aleatorios. Payment-service: 30% de fallos. Inventory-service: 20% de fallos.",
      "item": [
